# VITE_OPENAI_API_URL: Cloudflare Worker proxy endpoint (CORS-friendly).
# Example: https://piaq-openai-proxy.<account>.workers.dev/v1/chat/completions
VITE_OPENAI_API_URL="https://your-worker.example.com/v1/chat/completions"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_URL: Optional base URL for the backend API.
# - In local dev we proxy /devices, /ingest, /health to http://localhost:5001 by default (see vite.config.ts)
# - If you deploy frontend + backend separately, set this to the backend origin, e.g. http://localhost:5001
VITE_API_URL="http://172.17.78.57:5000"
